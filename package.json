{
  "name": "ytmusicplaylistmaker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron:watch\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron:watch": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/electron/main.js && electron .",
    "typecheck": "tsc -b",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.electron.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.ytmusicplaylistmaker.app",
    "productName": "YT Music Playlist Maker",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    }
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.2",
    "@mui/material": "^7.3.2",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-query-devtools": "^5.90.2",
    "dotenv": "^17.2.2",
    "googleapis": "^159.0.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-dropzone": "^14.3.8",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "electron": "^38.1.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^17.7.0",
    "prettier": "^3.6.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "wait-on": "^9.0.1"
  }
}
